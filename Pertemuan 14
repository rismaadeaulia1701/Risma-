.timeline-item h3{
    color:#7d3cff;
}

.contact{
    text-align:center;
}

.contact-box{
    background:rgba(255,255,255,0.7);
    padding:40px;
    border-radius:25px;
    max-width:700px;
    margin:auto;
    box-shadow:0 10px 30px rgba(0,0,0,0.08);
}

footer{
