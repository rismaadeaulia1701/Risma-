}

.hero p{
    margin-top:15px;
    line-height:1.8;
}

.btn{
    display:inline-block;
    margin-top:25px;
    padding:12px 30px;
    background:linear-gradient(45deg,#8b5cf6,#ec4899);
    color:white;
    text-decoration:none;
    border-radius:50px;
    transition:.3s;
}

.btn:hover{
    transform:translateY(-3px);
}

section{
    padding:80px 0;
}

.title{
    text-align:center;
    margin-bottom:50px;
}

.title h2{
    font-size:2.3rem;
    color:#7d3cff;
}

.grid{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(300px,1fr));
    gap:25px;
}

.card{
    background:rgba(255,255,255,0.6);
    backdrop-filter:blur(10px);
    border-radius:20px;
    padding:25px;
    box-shadow:0 10px 25px rgba(0,0,0,0.08);
    transition:.3s;
}

.card:hover{
    transform:translateY(-8px);
}

.card h3{
    color:#7d3cff;
    margin-bottom:10px;
}

.card p{
    line-height:1.8;
